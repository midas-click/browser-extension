{
  "manifest_version": 3,
  "name": "Midas Click",
  "description": "Create jobs and applications from the current job posting page.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Midas Click"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://midas-click.onrender.com/*",
    "https://midas-click.netlify.app/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://midas-click.netlify.app/*"
    ]
  }
}
